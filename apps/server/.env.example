DATABASE_URL="postgresql://USER:PASS@HOST:PORT/DBNAME?schema=public"
PORT=3000
NODE_ENV=development

# Email (Resend). If RESEND_API_KEY is unset, sends are logged to stdout instead.
RESEND_API_KEY=
# Default: hello@entuned.co (must be a verified Resend domain sender)
EMAIL_FROM=
# Default: hello@entuned.co
EMAIL_REPLY_TO=

# Internal admin token — required by POST /admin/email/preview (header: x-admin-token)
INTERNAL_ADMIN_TOKEN=

# ---------- Customer dashboard auth (User / Account / magic-link / Google OAuth) ----------
# Long random string (>=32 bytes recommended). Used to sign session JWTs in the entuned_session cookie.
JWT_SECRET=

# Google OAuth client (Cloud Console > APIs & Services > Credentials).
# (deferred — uncomment in routes/login.ts to enable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match an Authorized redirect URI in the Google client config.
# Prod: https://api.entuned.co/login/google/callback
GOOGLE_REDIRECT_URI=http://localhost:3000/login/google/callback

# Where the magic-link email points the user. The server's /login/verify endpoint
# consumes the token and sets the session cookie before redirecting to APP_URL.
# Prod: https://api.entuned.co/login/verify
MAGIC_LINK_BASE_URL=http://localhost:3000/login/verify

# Where to redirect users after a successful login.
# Prod: https://app.entuned.co
APP_URL=http://localhost:5173

# Cookie domain for the session cookie. In prod set to ".entuned.co" so it's shared across
# api.entuned.co / app.entuned.co. Leave blank in dev (localhost).
COOKIE_DOMAIN=

# ---------- Billing (Stripe) ----------
# Server-side secret key (sk_test_... in dev, sk_live_... in production).
STRIPE_SECRET_KEY=
# Publishable key (pk_test_... / pk_live_...). Not required server-side for
# Checkout, but kept here so the player/admin builds can read it from the
# same source.
STRIPE_PUBLISHABLE_KEY=
# Webhook signing secret from Stripe Dashboard → Developers → Webhooks.
# Required to verify `POST /webhooks/stripe` payloads.
STRIPE_WEBHOOK_SECRET=
# Stripe Price IDs (price_...) for the two paid tiers. Per-unit pricing
# assumed — adding a Location bumps `quantity` on the existing subscription.
STRIPE_PRICE_ID_CORE=
STRIPE_PRICE_ID_PRO=

# Public-facing brand site (used for Checkout cancel_url).
# Prod: https://entuned.co
WEBSITE_URL=https://entuned.co

# In-store player root (used for welcome email's per-Location player URL).
# Prod: https://play.entuned.co
PLAYER_URL=http://localhost:5174
