// entuned-0.3 — Prisma schema
// SSOT lives in `../../../entune v0.3/schema/` — keep this file in sync.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [citext]
}

// ---------- enums ----------

enum TasteCategory {
  PreFormation
  FormationEra
  Subculture
  Aspirational
  Adjacent
}

// PlaybackEventType was demoted from a Postgres enum to TEXT on 2026-05-16 so
// new telemetry event types (lockscreen/wake/visibility/stall/PWA) ship as
// code-only deploys. The allow-list is enforced at the Zod boundary in
// apps/server/src/routes/events.ts. Same pattern as Store.tier.

enum ReportReason {
  NotOurVibe      @map("Not our Vibe")
  Boring
  AwkwardLyrics   @map("Awkward Lyrics")
  TooSlow         @map("Too Slow")
  TooIntense      @map("Too Intense")
  SongAudioIssues @map("Song Audio Issues")
}

enum ClientPlan {
  mvp_pilot
  trial
  paid_pilot
  production
  paused
  inactive
}

// ---------- Auth (unified Account, replaces prior Operator + User) ----------

// One identity per person. Authenticates either surface — the customer
// dashboard (cookie session, /login/*) or the in-store admin/Dash (Bearer
// JWT, /auth/*) — by resolving to the same row. See entune v0.3/schema/auth.md.
model Account {
  id                    String    @id @default(uuid()) @db.Uuid
  email                 String    @unique @db.Citext
  // Display name. Was `display_name` on Operator and `name` on User —
  // canonicalized to `name` in the merge.
  name                  String?
  // Nullable: magic-link / Google-only accounts have no password.
  passwordHash          String?   @map("password_hash")
  googleSub             String?   @unique @map("google_sub")
  isAdmin               Boolean   @default(false) @map("is_admin")
  // Behavioral / lifecycle email opt-out. Unsubscribe link in every drip
  // flips this to true. Transactional mail (magic link, dunning, welcome,
  // pause-ending) ignores this flag — those are operationally required.
  lifecycleEmailsOptOut Boolean   @default(false) @map("lifecycle_emails_opt_out")
  disabledAt            DateTime? @map("disabled_at") @db.Timestamptz(6)
  createdAt             DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById           String?   @map("created_by") @db.Uuid
  passwordSetAt         DateTime  @default(now()) @map("password_set_at") @db.Timestamptz(6)
  lastLoginAt           DateTime? @map("last_login_at") @db.Timestamptz(6)
  // Bumped on password change, admin-triggered revoke, email change, or
  // self-serve disable. Baked into the JWT payload (`tv`) AND the session
  // cookie so previously-issued tokens stop validating on either surface.
  tokenVersion          Int       @default(0) @map("token_version")

  createdBy           Account?             @relation("AccountCreator", fields: [createdById], references: [id], onDelete: SetNull)
  createdOthers       Account[]            @relation("AccountCreator")
  storeAssignments    StoreAssignment[]    @relation("AccountAssignments")
  assignmentsMade     StoreAssignment[]    @relation("AccountAssigner")
  playbackEvents      PlaybackEvent[]
  passwordResetTokens PasswordResetToken[]
  memberships         ClientMembership[]
  lifecycleEmails     LifecycleEmailLog[]
  pushSubscriptions   PushSubscription[]

  @@map("accounts")
}

model StoreAssignment {
  accountId    String   @map("account_id") @db.Uuid
  storeId      String   @map("store_id") @db.Uuid
  assignedAt   DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)
  assignedById String   @map("assigned_by") @db.Uuid

  account    Account @relation("AccountAssignments", fields: [accountId], references: [id], onDelete: Cascade)
  store      Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  assignedBy Account @relation("AccountAssigner", fields: [assignedById], references: [id])

  @@id([accountId, storeId])
  @@index([storeId])
  @@map("store_assignments")
}

// ---------- Card 3 Duke (Client + Store) ----------

model Client {
  id                   String     @id @default(uuid()) @db.Uuid
  companyName          String     @map("company_name")
  contactName          String?    @map("contact_name")
  contactEmail         String?    @map("contact_email") @db.Citext
  contactPhone         String?    @map("contact_phone")
  plan                 ClientPlan @default(mvp_pilot)
  posProvider          String?    @map("pos_provider")
  posCredentials       Json?      @map("pos_credentials")
  brandLyricGuidelines String?    @map("brand_lyric_guidelines")
  // Stripe customer id; absorbed from the dropped `Account` table 2026-05-04.
  // Null for operator-managed Clients (Untuckit, Lululemon, Friends-Demo) that
  // never went through Stripe Checkout.
  stripeCustomerId     String?    @unique @map("stripe_customer_id")
  // Onboarding profile — collected at /onboard (post-auth, pre-dashboard gate).
  // `industry` null = onboarding not yet complete; server redirects to /onboard on login.
  industry             String?    @map("industry")
  zip                  String?    @map("zip")
  // Post-conversion benchmarking — collected 7 days after paid conversion.
  annualRevenueRange   String?    @map("annual_revenue_range")
  employeeCountRange   String?    @map("employee_count_range")
  storeLocationCount   Int?       @map("store_location_count")
  // Referral tracking — lazy-generated on first referral prompt access.
  referralCode         String?    @unique @map("referral_code")
  referredByCode       String?    @map("referred_by_code")
  createdAt            DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime   @updatedAt @map("updated_at") @db.Timestamptz(6)

  stores      Store[]
  icps        ICP[]
  posPullRuns POSPullRun[]
  memberships ClientMembership[]

  @@index([companyName])
  @@map("clients")
}

model Store {
  id                          String    @id @default(uuid()) @db.Uuid
  clientId                    String    @map("client_id") @db.Uuid
  name                        String
  timezone                    String
  goLiveDate                  DateTime? @map("go_live_date") @db.Date
  posLocationId               String?   @map("pos_location_id")
  defaultOutcomeId            String?   @map("default_outcome_id") @db.Uuid
  outcomeSelectionId          String?   @map("outcome_selection_id") @db.Uuid
  outcomeSelectionExpiresAt   DateTime? @map("outcome_selection_expires_at") @db.Timestamptz(6)
  roomLoudnessSamplingEnabled Boolean   @default(false) @map("room_loudness_sampling_enabled")
  // Customer-dashboard fields absorbed from the dropped `Location` table 2026-05-04.
  // `slug` is the URL fragment for music.entuned.co/<slug>. `tier` is a string
  // (not enum) so adding tiers doesn't require a migration.
  slug                        String    @unique
  tier                        String    @default("mvp_pilot") // 'free' | 'core' | 'pro' | 'enterprise' | 'mvp_pilot' — Stripe-authoritative
  pausedUntil                 DateTime? @map("paused_until") @db.Timestamptz(6)
  archivedAt                  DateTime? @map("archived_at") @db.Timestamptz(6)
  // Comp-tier override (admin-granted free upgrade). Effective tier =
  // max(tier, compTier) while the comp is active. See `effectiveTier()` in
  // server/src/lib/tier.ts. Schema-side: 03-duke.md "Comp tier" section.
  compTier                    String?   @map("comp_tier")
  compExpiresAt               DateTime? @map("comp_expires_at") @db.Timestamptz(6)
  compReason                  String?   @map("comp_reason")
  compGrantedById             String?   @map("comp_granted_by") @db.Uuid
  compGrantedAt               DateTime? @map("comp_granted_at") @db.Timestamptz(6)
  createdAt                   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                   DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  client                    Client                     @relation(fields: [clientId], references: [id])
  icpLinks                  StoreICP[]
  defaultOutcome            Outcome?                   @relation("StoreDefaultOutcome", fields: [defaultOutcomeId], references: [id])
  outcomeSelection          Outcome?                   @relation("StoreOutcomeSelection", fields: [outcomeSelectionId], references: [id])
  scheduleSlots             ScheduleSlot[]
  storeAssignments          StoreAssignment[]
  playbackEvents            PlaybackEvent[]
  posEvents                 POSEvent[]
  posPullRuns               POSPullRun[]
  campaigns                 Campaign[]
  campaignPlayState         CampaignPlayState?
  retailNextIngestRuns      RetailNextIngestRun[]
  retailNextDailySnapshots  RetailNextDailySnapshot[]
  retailNextHourlySnapshots RetailNextHourlySnapshot[]
  subscription              Subscription?
  binding                   PlayerBinding?
  tierChangeLogs            TierChangeLog[]
  retiredSongs              StoreRetiredSong[]
  pushSubscriptions         PushSubscription[]

  @@index([clientId])
  @@map("stores")
}

// ---------- Tier change audit log ----------
//
// Append-only timeline of effective-tier transitions for a Store. Written on
// admin grant/revoke, Stripe webhook tier changes, pause/resume, and comp
// expiry. `from_tier`/`to_tier` capture *effective* tier (post-comp) so the
// log reads as a clean entitlement timeline. See 03-duke.md "TierChangeLog".

model TierChangeLog {
  id        String    @id @default(uuid()) @db.Uuid
  storeId   String    @map("store_id") @db.Uuid
  fromTier  String    @map("from_tier")
  toTier    String    @map("to_tier")
  source    String // 'admin_comp' | 'admin_revoke' | 'stripe_webhook' | 'pause' | 'resume' | 'comp_expired' | 'auto_cleared'
  actorId   String?   @map("actor_id") @db.Uuid
  reason    String?
  expiresAt DateTime? @map("expires_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([storeId, createdAt(sort: Desc)])
  @@map("tier_change_logs")
}

// ---------- Card 4 Gains (ICP) ----------

model ICP {
  id                 String    @id @default(uuid()) @db.Uuid
  clientId           String    @map("client_id") @db.Uuid
  name               String
  ageRange           String?   @map("age_range")
  location           String?
  politicalSpectrum  String?   @map("political_spectrum")
  openness           String?
  fears              String?
  values             String?
  desires            String?
  unexpressedDesires String?   @map("unexpressed_desires")
  turnOffs           String?   @map("turn_offs")
  // Source flag: 'operator' (default) = created via Dash or /intake form;
  // 'onboarding' = created by POST /me/boost-trial self-serve flow.
  source             String    @default("operator")
  // Onboarding ICP — forced-choice fields from the /boost-trial form.
  // Null on all operator-created ICPs.
  icpAgeCenter        String?   @map("icp_age_center")
  icpAgeRangeWide     Boolean?  @map("icp_age_range_wide")
  icpGenderSkew       String?   @map("icp_gender_skew")
  icpShoppingMode     String?   @map("icp_shopping_mode")
  icpStorePersonality String?   @map("icp_store_personality")
  icpCurrentMusic     String?   @map("icp_current_music")
  icpCurrentMusicOther String?  @map("icp_current_music_other")
  icpPlaylistRef      String?   @map("icp_playlist_ref")
  icpPricePoint       String?   @map("icp_price_point")
  // Customer-dashboard "Retire" — soft-delete. Retired ICPs are hidden from the
  // dashboard and from generation (Hendrix queries filter `archivedAt: null`),
  // and their LineageRows are flipped to `active=false`. Rows are preserved so
  // the audience and its songs can be restored.
  archivedAt         DateTime? @map("archived_at") @db.Timestamptz(6)
  createdAt          DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt          DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  client           Client            @relation(fields: [clientId], references: [id])
  storeLinks       StoreICP[]
  hooks            Hook[]
  referenceTracks  ReferenceTrack[]
  hookWriterPrompt HookWriterPrompt?
  lineageRows      LineageRow[]

  @@index([clientId])
  @@map("icps")
}

// Store ↔ ICP many-to-many. Replaces the legacy `ICP.store_id` 1:N FK so the
// canonical Free Tier ICP can serve every free Store, while paid Stores can
// continue to have their own (or shared) ICP set. See entune v0.3/schema/04-gains.md.
model StoreICP {
  storeId   String   @map("store_id") @db.Uuid
  icpId     String   @map("icp_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  icp   ICP   @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@id([storeId, icpId])
  @@index([icpId])
  @@map("store_icps")
}

// ---------- Card 4 ReferenceTrack ----------

enum ReferenceTrackStatus {
  pending
  approved
  rejected
  archived
}

model ReferenceTrack {
  id                 String               @id @default(uuid()) @db.Uuid
  icpId              String               @map("icp_id") @db.Uuid
  bucket             TasteCategory
  artist             String
  title              String
  year               Int?
  operatorNotes      String?              @map("operator_notes")
  status             ReferenceTrackStatus @default(approved)
  suggestedRationale String?              @map("suggested_rationale")
  suggestedPromptVer Int?                 @map("suggested_prompt_version")
  suggestedAt        DateTime?            @map("suggested_at") @db.Timestamptz(6)
  approvedAt         DateTime?            @map("approved_at") @db.Timestamptz(6)
  approvedById       String?              @map("approved_by") @db.Uuid
  verifiedById       String?              @map("verified_by") @db.Uuid
  useCount           Int                  @default(0) @map("use_count")
  previewUrl         String?              @map("preview_url")
  previewSource      String?              @map("preview_source")
  coverUrl           String?              @map("cover_url")
  createdAt          DateTime             @default(now()) @map("created_at") @db.Timestamptz(6)

  icp           ICP            @relation(fields: [icpId], references: [id], onDelete: Cascade)
  styleAnalysis StyleAnalysis?
  songSeeds     SongSeed[]

  @@index([icpId, bucket])
  @@index([icpId, status])
  @@map("reference_tracks")
}

// ---------- Card 5 Style Analyzer ----------

model StyleAnalyzerInstructions {
  id          String   @id @default(uuid()) @db.Uuid
  version     Int      @unique
  rulesText   String   @map("rules_text")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  styleAnalyses StyleAnalysis[]

  @@map("style_analyzer_instructions")
}

model ProductionEra {
  id                  String   @id @default(uuid()) @db.Uuid
  decade              String
  genreSlug           String   @map("genre_slug")
  genreDisplayName    String?  @map("genre_display_name")
  isEraOverview       Boolean  @default(false) @map("is_era_overview")
  promptBlock         String?  @map("prompt_block")
  textureLanguage     String?  @map("texture_language")
  excludeList         String?  @map("exclude_list")
  bpmRangeLow         Int?     @map("bpm_range_low")
  bpmRangeHigh        Int?     @map("bpm_range_high")
  bpmCompensation     Int?     @map("bpm_compensation")
  extensionTechniques String?  @map("extension_techniques")
  instruments         String?
  recordingChain      String?  @map("recording_chain")
  vocalsDescription   String?  @map("vocals_description")
  sunoDriftNotes      String?  @map("suno_drift_notes")
  notes               String?
  isActive            Boolean  @default(true) @map("is_active")
  createdAt           DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  outcomes Outcome[]

  @@unique([decade, genreSlug])
  @@index([decade])
  @@map("production_eras")
}

model StyleAnalysis {
  id                               String    @id @default(uuid()) @db.Uuid
  referenceTrackId                 String    @unique @map("reference_track_id") @db.Uuid
  styleAnalyzerInstructionsVersion Int       @map("style_analyzer_instructions_version")
  status                           String    @default("draft")
  verifiedAt                       DateTime? @map("verified_at") @db.Timestamptz(6)
  verifiedById                     String?   @map("verified_by") @db.Uuid
  confidence                       String?
  vibePitch                        String?   @map("vibe_pitch")
  eraProductionSignature           String?   @map("era_production_signature")
  instrumentationPalette           String?   @map("instrumentation_palette")
  standoutElement                  String?   @map("standout_element")
  arrangementShape                 String?   @map("arrangement_shape")
  dynamicCurve                     String?   @map("dynamic_curve")
  vocalCharacter                   String?   @map("vocal_character")
  vocalArrangement                 String?   @map("vocal_arrangement")
  harmonicAndGroove                String?   @map("harmonic_and_groove")
  arrangementSections              Json?     @map("arrangement_sections")
  arrangementVersion               Int?      @map("arrangement_version")
  createdAt                        DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt                        DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  referenceTrack            ReferenceTrack            @relation(fields: [referenceTrackId], references: [id], onDelete: Cascade)
  styleAnalyzerInstructions StyleAnalyzerInstructions @relation(fields: [styleAnalyzerInstructionsVersion], references: [version])

  @@index([status])
  @@map("style_analyses")
}

// ---------- Card 12 Mars (StyleTemplate + StyleExclusionRule) ----------

model StyleTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  version      Int      @unique
  templateText String   @map("template_text")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById  String?  @map("created_by") @db.Uuid

  @@map("style_templates")
}

model StyleExclusionRule {
  id              String   @id @default(uuid()) @db.Uuid
  triggerField    String   @map("trigger_field")
  triggerValue    String   @map("trigger_value")
  exclude         String
  overrideField   String?  @map("override_field")
  overridePattern String?  @map("override_pattern")
  note            String?
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([triggerField])
  @@map("style_exclusion_rules")
}

// ---------- Card 13 Bernie (lyric prompts) ----------

model LyricDraftPrompt {
  id          String   @id @default(uuid()) @db.Uuid
  version     Int      @unique
  promptText  String   @map("prompt_text")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  @@map("lyric_draft_prompts")
}

model LyricEditPrompt {
  id          String   @id @default(uuid()) @db.Uuid
  version     Int      @unique
  promptText  String   @map("prompt_text")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  @@map("lyric_edit_prompts")
}

model LyricBanEntry {
  id        String   @id @default(uuid()) @db.Uuid
  category  String
  text      String
  note      String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@unique([category, text])
  @@index([category])
  @@map("lyric_ban_entries")
}

// ---------- Card 10 Hook Writer Prompt (per-ICP) ----------

model HookWriterPrompt {
  id          String   @id @default(uuid()) @db.Uuid
  icpId       String   @unique @map("icp_id") @db.Uuid
  promptText  String   @map("prompt_text")
  version     Int      @default(1)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById String?  @map("updated_by") @db.Uuid

  icp ICP @relation(fields: [icpId], references: [id], onDelete: Cascade)

  @@map("hook_writer_prompts")
}

model HookWriterPromptVersion {
  id          String   @id @default(uuid()) @db.Uuid
  icpId       String   @map("icp_id") @db.Uuid
  version     Int
  promptText  String   @map("prompt_text")
  notes       String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById String?  @map("created_by") @db.Uuid

  @@unique([icpId, version])
  @@index([icpId, version(sort: Desc)])
  @@map("hook_writer_prompt_versions")
}

// ---------- Card 14 Eno (OutcomeFactorPrompt, SongSeedBatch, SongSeed) ----------

model OutcomeFactorPrompt {
  id           String   @id @default(uuid()) @db.Uuid
  version      Int      @unique
  templateText String   @map("template_text")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById  String?  @map("created_by") @db.Uuid

  @@map("outcome_factor_prompts")
}

// ---------- Reference Track Suggester (system prompt for the Claude call that
// proposes ICP reference tracks from the psychographic profile) ----------

model ReferenceTrackPrompt {
  id           String   @id @default(uuid()) @db.Uuid
  version      Int      @unique
  templateText String   @map("template_text")
  notes        String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById  String?  @map("created_by") @db.Uuid

  @@map("reference_track_prompts")
}

model SongSeedBatch {
  id              String    @id @default(uuid()) @db.Uuid
  icpId           String    @map("icp_id") @db.Uuid
  outcomeId       String    @map("outcome_id") @db.Uuid
  requestedN      Int       @map("requested_n")
  producedN       Int?      @map("produced_n")
  reason          String?
  triggeredBy     String    @map("triggered_by")
  triggeredByUser String?   @map("triggered_by_user") @db.Uuid
  pipeline        String?   // eno-1 | eno-2; null = eno-1 for backward compat
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)

  songSeeds SongSeed[]

  @@index([icpId, startedAt(sort: Desc)])
  @@map("song_seed_batches")
}

model SongSeed {
  id               String  @id @default(uuid()) @db.Uuid
  songSeedBatchId  String  @map("song_seed_batch_id") @db.Uuid
  icpId            String  @map("icp_id") @db.Uuid
  hookId           String  @map("hook_id") @db.Uuid
  outcomeId        String  @map("outcome_id") @db.Uuid
  referenceTrackId String? @map("reference_track_id") @db.Uuid
  status           String  @default("assembling") // assembling|queued|accepted|failed
  pipeline         String? // eno-1 | eno-2; null = eno-1

  // Final Song Prompt payload
  style           String?
  stylePortionRaw String? @map("style_portion_raw")
  negativeStyle   String? @map("negative_style")
  vocalGender     String? @map("vocal_gender")
  lyrics          String?
  title           String?

  // Provenance snapshots
  outcomeFactorPromptVersion Int?     @map("outcome_factor_prompt_version")
  styleTemplateVersion       Int?     @map("style_template_version")
  lyricDraftPromptVersion    Int?     @map("lyric_draft_prompt_version")
  lyricEditPromptVersion     Int?     @map("lyric_edit_prompt_version")
  arrangementTemplateVersion Int?     @map("arrangement_template_version")
  resolvedTempoBpm           Int?     @map("resolved_tempo_bpm")
  resolvedMode               String?  @map("resolved_mode")
  firedExclusionRuleIds      String[] @map("fired_exclusion_rule_ids") @db.Uuid
  genreBrief                 String?  @map("genre_brief")
  errorText                  String?  @map("error_text")

  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  terminalAt DateTime? @map("terminal_at") @db.Timestamptz(6)

  songSeedBatch  SongSeedBatch   @relation(fields: [songSeedBatchId], references: [id])
  hook           Hook            @relation(fields: [hookId], references: [id], onDelete: Cascade)
  outcome        Outcome         @relation(fields: [outcomeId], references: [id])
  referenceTrack ReferenceTrack? @relation(fields: [referenceTrackId], references: [id])
  lineageRows    LineageRow[]

  @@index([songSeedBatchId])
  @@index([status])
  @@index([icpId, status])
  @@index([hookId])
  @@map("song_seeds")
}

// ---------- Card 9 Stones (Outcome, copy-on-write versioned) ----------

model Outcome {
  id              String    @id @default(uuid()) @db.Uuid
  outcomeKey      String    @map("outcome_key") @db.Uuid
  version         Int
  title           String
  displayTitle    String?   @map("display_title")
  // Song Outcome Specs
  tempoBpm        Int       @map("tempo_bpm")
  tempoBpmRadius  Int?      @map("tempo_bpm_radius")
  mode            String
  modeWeights     Json?     @map("mode_weights")
  mood            String
  dynamics        String?
  instrumentation String?
  // Research-backed signals
  familiarity     String?   @map("familiarity") // unfamiliar | familiar | neutral — Hendrix rotation signal
  productionEraId String?   @map("production_era_id") @db.Uuid // → ProductionEra; Mars pulls era sonic descriptors
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  createdById     String?   @map("created_by") @db.Uuid
  supersededAt    DateTime? @map("superseded_at") @db.Timestamptz(6)

  storesAsDefault             Store[]         @relation("StoreDefaultOutcome")
  storesAsSelection           Store[]         @relation("StoreOutcomeSelection")
  scheduleSlots               ScheduleSlot[]
  hooks                       Hook[]
  lineageRows                 LineageRow[]
  songSeeds                   SongSeed[]
  productionEra               ProductionEra?  @relation(fields: [productionEraId], references: [id])
  playbackEventsAsEffective   PlaybackEvent[] @relation("PlaybackEventEffectiveOutcome")

  @@unique([outcomeKey, version])
  @@index([outcomeKey, version(sort: Desc)])
  @@map("outcomes")
}

// ---------- FreeTierOutcome ----------
// Operator-curated allowlist of outcomes available to free-tier stores.
// Keyed by outcomeKey (durable across Outcome version bumps). Operators
// toggle entries via Dash to gate or temporarily unlock outcomes for free
// users (PLG upgrade friction + promo demos).
model FreeTierOutcome {
  outcomeKey String   @id @map("outcome_key") @db.Uuid
  enabledAt  DateTime @default(now()) @map("enabled_at") @db.Timestamptz(6)

  @@map("free_tier_outcomes")
}

// ---------- FormArchetype ----------
// Operator-editable catalogue of song-form archetypes (VCVCBC, AABA, VCVC, etc.).
// Eno picks one per generation and passes its sectionList + shapeNote into Bernie
// so the lyric writer knows which form to write into. Without this table Bernie's
// draft prompt hardcoded a single shape (V/C/V/C/Bridge/Final C) and every song
// collapsed to the same arrangement. SSOT: ../entune v0.3/schema/light-cards.md.
//
// outcomeWeights JSON shape: { [outcomeKey]: number, "*": number }. Keys are
// outcome_key (stable cross-version identity), not version-pinned id. Missing
// keys fall back to "*" then to 1.
//
// eraWeights JSON shape: { ranges: [{ minYear, maxYear, weight }] }. When set,
// each range that contains the reference track's year multiplies the base
// weight; when no range matches, weight = 0. Null = era-agnostic.
//
// requiresSections: section keys (intro, verse, pre_chorus, chorus, bridge,
// outro) that must exist in the reference track's arrangementSections for this
// archetype to be eligible. Empty = no constraint.
model FormArchetype {
  id               String   @id @default(uuid()) @db.Uuid
  slug             String   @unique
  displayName      String   @map("display_name")
  sectionList      String   @map("section_list")
  shapeNote        String   @map("shape_note")
  requiresSections String[] @default([]) @map("requires_sections")
  outcomeWeights   Json     @default("{}") @map("outcome_weights")
  eraWeights       Json?    @map("era_weights")
  isActive         Boolean  @default(true) @map("is_active")
  notes            String?
  createdAt        DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt        DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@index([isActive])
  @@map("form_archetypes")
}

// ---------- OutcomeLyricFactor ----------
// Per-outcome editable guidance string injected into the Hook Drafter prompt.
// Keyed by outcomeKey (not version-pinned id) so operators can iterate without
// spawning new Outcome versions. Mutable in place; latest-wins.
model OutcomeLyricFactor {
  outcomeKey   String   @id @map("outcome_key") @db.Uuid
  templateText String   @default("") @map("template_text")
  hookPrompt   String?  @map("hook_prompt")
  notes        String?
  updatedAt    DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById  String?  @map("updated_by") @db.Uuid

  @@map("outcome_lyric_factors")
}

// ---------- Card 8 Dayparting (ScheduleSlot) ----------

model ScheduleSlot {
  id        String   @id @default(uuid()) @db.Uuid
  storeId   String   @map("store_id") @db.Uuid
  dayOfWeek Int      @map("day_of_week")
  startTime DateTime @map("start_time") @db.Time(6)
  endTime   DateTime @map("end_time") @db.Time(6)
  outcomeId String   @map("outcome_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  store   Store   @relation(fields: [storeId], references: [id], onDelete: Cascade)
  outcome Outcome @relation(fields: [outcomeId], references: [id])

  @@index([storeId, dayOfWeek])
  @@map("schedule_slots")
}

// ---------- Card 10 Hooks ----------

model Hook {
  id              String    @id @default(uuid()) @db.Uuid
  icpId           String    @map("icp_id") @db.Uuid
  outcomeId       String    @map("outcome_id") @db.Uuid
  text            String
  vocalGender     String?   @map("vocal_gender") // null = unconstrained; 'male' | 'female' | 'duet' if hook is gender-specific
  status          String    @default("draft") // draft | approved | rejected | retired
  rejectionReason String?   @map("rejection_reason") // free-form reason captured when status flips to 'rejected'; teaching signal for next drafter batch
  useCount        Int       @default(0) @map("use_count") // incremented each time this hook seeds an accepted song
  approvedAt      DateTime? @map("approved_at") @db.Timestamptz(6)
  approvedById    String?   @map("approved_by") @db.Uuid
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  icp         ICP          @relation(fields: [icpId], references: [id], onDelete: Cascade)
  outcome     Outcome      @relation(fields: [outcomeId], references: [id])
  lineageRows LineageRow[]
  songSeeds   SongSeed[]

  @@index([icpId, status])
  @@index([outcomeId])
  @@map("hooks")
}

// ---------- Card 17 Song Library ----------

model Song {
  id          String   @id @default(uuid()) @db.Uuid
  r2Url       String   @unique @map("r2_url")
  r2ObjectKey String   @unique @map("r2_object_key")
  byteSize    BigInt?  @map("byte_size")
  contentType String?  @map("content_type")
  uploadedAt  DateTime @default(now()) @map("uploaded_at") @db.Timestamptz(6)

  lineageRows         LineageRow[]
  playbackEvents      PlaybackEvent[]
  storeRetiredEntries StoreRetiredSong[]

  @@map("songs")
}

// ---------- Per-store song suppression (free-tier flagged-review) ----------
// LineageRow.active is global per ICP; free-tier stores share one ICP, so a
// global retire is too blunt. This table lets an operator retire a single song
// for one location without affecting other locations on the same shared pool.

model StoreRetiredSong {
  storeId   String   @map("store_id") @db.Uuid
  songId    String   @map("song_id") @db.Uuid
  reason    String?
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)
  song  Song  @relation(fields: [songId], references: [id])

  @@id([storeId, songId])
  @@index([songId])
  @@map("store_retired_songs")
}

// ---------- Card 16 LineageRow (song pool Hendrix reads) ----------

model LineageRow {
  id             String   @id @default(uuid()) @db.Uuid
  songId         String   @map("song_id") @db.Uuid
  r2Url          String   @map("r2_url")
  // Every LineageRow has an ICP. Free-tier hand-curated rows point at the
  // canonical Free Tier ICP (Card 04 Gains). hookId stays nullable because
  // those hand-curated songs have no generation Hook.
  icpId          String   @map("icp_id") @db.Uuid
  outcomeId      String   @map("outcome_id") @db.Uuid
  outcomeVersion Int?     @map("outcome_version") // scope stamp — required for Kraftwerk baseline isolation
  hookId         String?  @map("hook_id") @db.Uuid
  songSeedId     String?  @map("song_seed_id") @db.Uuid
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  song     Song      @relation(fields: [songId], references: [id])
  icp      ICP       @relation(fields: [icpId], references: [id], onDelete: Cascade)
  outcome  Outcome   @relation(fields: [outcomeId], references: [id])
  hook     Hook?     @relation(fields: [hookId], references: [id], onDelete: SetNull)
  songSeed SongSeed? @relation(fields: [songSeedId], references: [id])

  @@index([icpId, outcomeId, active])
  @@index([hookId])
  @@index([songId])
  @@map("lineage_rows")
}

// ---------- Card 18 Hendrix (PlaybackRules singleton) ----------

model PlaybackRules {
  id                    String   @id @default(uuid()) @db.Uuid
  siblingSpacingMinutes Int      @default(240) @map("sibling_spacing_minutes")
  noRepeatWindowMinutes Int      @default(45) @map("no_repeat_window_minutes")
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  updatedById           String?  @map("updated_by") @db.Uuid

  @@map("playback_rules")
}

// ---------- Card 20 PlaybackEvent (append-only) ----------

model PlaybackEvent {
  id           String            @id @default(uuid()) @db.Uuid
  eventType    String            @map("event_type")
  storeId      String            @map("store_id") @db.Uuid
  occurredAt   DateTime          @map("occurred_at") @db.Timestamptz(6)
  receivedAt   DateTime          @default(now()) @map("received_at") @db.Timestamptz(6)
  // Account that caused the event. Was `operator_id` (FK → operators); now
  // points at the unified Account table. Free-tier owners signed into their
  // own player log here too — no longer NULL just because the actor isn't an
  // in-store Operator.
  accountId    String?           @map("account_id") @db.Uuid
  songId       String?           @map("song_id") @db.Uuid
  hookId       String?           @map("hook_id") @db.Uuid
  reportReason ReportReason?     @map("report_reason")
  outcomeId    String?           @map("outcome_id") @db.Uuid
  extra        Json?
  // Phase-3 (2026-05-17). See schema/20-audio-event-stream.md for semantics
  // and POS-correlation rationale.
  playbackSessionId   String?  @map("playback_session_id") @db.Uuid
  deviceId            String?  @map("device_id")
  playDurationMs      Int?     @map("play_duration_ms")
  completionReason    String?  @map("completion_reason")
  effectiveOutcomeId  String?  @map("effective_outcome_id") @db.Uuid
  clientSentAt        DateTime? @map("client_sent_at") @db.Timestamptz(6)
  clientBuild         String?  @map("client_build")
  idempotencyKey      String?  @unique @map("idempotency_key")

  store            Store    @relation(fields: [storeId], references: [id])
  account          Account? @relation(fields: [accountId], references: [id])
  song             Song?    @relation(fields: [songId], references: [id])
  effectiveOutcome Outcome? @relation("PlaybackEventEffectiveOutcome", fields: [effectiveOutcomeId], references: [id])

  @@index([storeId, songId, occurredAt(sort: Desc)])
  @@index([storeId, hookId, occurredAt(sort: Desc)])
  @@index([storeId, occurredAt(sort: Desc)])
  @@index([storeId, eventType, occurredAt(sort: Desc)])
  @@index([storeId, playbackSessionId, occurredAt])
  @@map("playback_events")
}

// Quarantine for events the zod allow-list rejected. Stale players or new
// event types ship without losing telemetry — Daniel promotes to the allow-
// list and either replays or discards. See schema/20-audio-event-stream.md.
model PlaybackEventRaw {
  id         String   @id @default(uuid()) @db.Uuid
  receivedAt DateTime @default(now()) @map("received_at") @db.Timestamptz(6)
  rawJson    Json     @map("raw_json")
  errorText  String?  @map("error_text")
  storeId    String?  @map("store_id") @db.Uuid
  eventType  String?  @map("event_type")

  @@index([receivedAt(sort: Desc)])
  @@index([eventType, receivedAt(sort: Desc)])
  @@map("playback_events_raw")
}

// ---------- Web Push subscriptions (iOS 16.4+ + Android) ----------
// One row per (device, store) — endpoint is the device-specific URL the user
// agent generates from VAPID. Used by the playback-heartbeat cron to send
// "music paused — tap to resume" nudges when an active session goes silent
// without an explicit operator pause. iOS requires the player to be installed
// as a PWA before push registration succeeds; Android works in either mode.

model PushSubscription {
  id           String    @id @default(uuid()) @db.Uuid
  storeId      String    @map("store_id") @db.Uuid
  accountId    String?   @map("account_id") @db.Uuid
  endpoint     String    @unique
  p256dhKey    String    @map("p256dh_key")
  authKey      String    @map("auth_key")
  userAgent    String?   @map("user_agent")
  createdAt    DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  lastNudgedAt DateTime? @map("last_nudged_at") @db.Timestamptz(6)

  store   Store    @relation(fields: [storeId], references: [id], onDelete: Cascade)
  account Account? @relation(fields: [accountId], references: [id], onDelete: SetNull)

  @@index([storeId])
  @@map("push_subscriptions")
}

// ---------- Card 21 POS Ingestion ----------

model POSPullRun {
  id              String    @id @default(uuid()) @db.Uuid
  clientId        String    @map("client_id") @db.Uuid
  storeId         String    @map("store_id") @db.Uuid
  posProvider     String    @map("pos_provider")
  pullWindowStart DateTime  @map("pull_window_start") @db.Timestamptz(6)
  pullWindowEnd   DateTime  @map("pull_window_end") @db.Timestamptz(6)
  startedAt       DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt      DateTime? @map("finished_at") @db.Timestamptz(6)
  status          String    @default("running") // running | success | failed
  eventsIngested  Int?      @map("events_ingested")
  unmappedCount   Int?      @map("unmapped_count")
  errorText       String?   @map("error_text")
  triggeredBy     String    @default("manual") @map("triggered_by") // manual | scheduled
  triggeredById   String?   @map("triggered_by_id") @db.Uuid

  client    Client     @relation(fields: [clientId], references: [id])
  store     Store      @relation(fields: [storeId], references: [id])
  posEvents POSEvent[]

  @@index([clientId, startedAt(sort: Desc)])
  @@index([clientId, status])
  @@index([storeId, startedAt(sort: Desc)])
  @@map("pos_pull_runs")
}

model POSEvent {
  id                    String   @id @default(uuid()) @db.Uuid
  storeId               String   @map("store_id") @db.Uuid
  clientId              String   @map("client_id") @db.Uuid
  posProvider           String   @map("pos_provider")
  posExternalId         String?  @map("pos_external_id")
  occurredAt            DateTime @map("occurred_at") @db.Timestamptz(6)
  transactionValueCents BigInt   @map("transaction_value_cents")
  currency              String   @default("USD")
  itemCount             Int      @map("item_count")
  posPullRunId          String   @map("pos_pull_run_id") @db.Uuid
  receivedAt            DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  store      Store      @relation(fields: [storeId], references: [id])
  posPullRun POSPullRun @relation(fields: [posPullRunId], references: [id])

  @@unique([posProvider, posExternalId])
  @@index([storeId, occurredAt(sort: Desc)])
  @@index([clientId, occurredAt(sort: Desc)])
  @@map("pos_events")
}

// ---------- Card 22 Campaigns (Interstitial Ads) ----------

model Campaign {
  id         String   @id @default(uuid()) @db.Uuid
  storeId    String   @map("store_id") @db.Uuid
  name       String
  startsAt   DateTime @map("starts_at") @db.Timestamptz(6)
  endsAt     DateTime @map("ends_at") @db.Timestamptz(6)
  songsPerAd Int      @default(3) @map("songs_per_ad")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  store      Store               @relation(fields: [storeId], references: [id], onDelete: Cascade)
  adAssets   AdAsset[]
  assetState CampaignAssetState?

  @@index([storeId, startsAt])
  @@map("campaigns")
}

model AdAsset {
  id          String   @id @default(uuid()) @db.Uuid
  campaignId  String   @map("campaign_id") @db.Uuid
  r2Url       String   @map("r2_url")
  r2ObjectKey String   @map("r2_object_key")
  label       String?
  position    Int
  byteSize    BigInt?  @map("byte_size")
  contentType String?  @map("content_type")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@index([campaignId, position])
  @@map("ad_assets")
}

model CampaignPlayState {
  storeId            String   @id @map("store_id") @db.Uuid
  songsPlayedSinceAd Int      @default(0) @map("songs_played_since_ad")
  updatedAt          DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("campaign_play_states")
}

model CampaignAssetState {
  campaignId     String   @id @map("campaign_id") @db.Uuid
  nextAssetIndex Int      @default(0) @map("next_asset_index")
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)

  @@map("campaign_asset_states")
}

// ---------- RetailNext Ingestion ----------

model RetailNextIngestRun {
  id            String    @id @default(uuid()) @db.Uuid
  storeId       String    @map("store_id") @db.Uuid
  reportDate    DateTime  @map("report_date") @db.Date
  filename      String?
  status        String    @default("running") // running | success | failed
  rowsIngested  Int?      @map("rows_ingested")
  errorText     String?   @map("error_text")
  startedAt     DateTime  @default(now()) @map("started_at") @db.Timestamptz(6)
  finishedAt    DateTime? @map("finished_at") @db.Timestamptz(6)
  triggeredById String?   @map("triggered_by_id") @db.Uuid

  store           Store                      @relation(fields: [storeId], references: [id])
  dailySnapshots  RetailNextDailySnapshot[]
  hourlySnapshots RetailNextHourlySnapshot[]

  @@index([storeId, startedAt(sort: Desc)])
  @@map("retailnext_ingest_runs")
}

model RetailNextDailySnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  storeId           String   @map("store_id") @db.Uuid
  date              DateTime @map("date") @db.Date
  retailNextStoreId String?  @map("retailnext_store_id") // e.g. "015"
  traffic           Int?
  salesCents        BigInt?  @map("sales_cents")
  saleTrxCount      Int?     @map("sale_trx_count")
  returnTrxCount    Int?     @map("return_trx_count")
  convRate          Float?   @map("conv_rate")
  atv               Float?
  shopperYield      Float?   @map("shopper_yield")
  captureRate       Float?   @map("capture_rate")
  newShopperPct     Float?   @map("new_shopper_pct")
  visitDurationSecs Int?     @map("visit_duration_secs")
  weather           String?
  ingestRunId       String   @map("ingest_run_id") @db.Uuid
  receivedAt        DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  store     Store               @relation(fields: [storeId], references: [id])
  ingestRun RetailNextIngestRun @relation(fields: [ingestRunId], references: [id])

  @@unique([storeId, date])
  @@index([storeId, date(sort: Desc)])
  @@map("retailnext_daily_snapshots")
}

model RetailNextHourlySnapshot {
  id                String   @id @default(uuid()) @db.Uuid
  storeId           String   @map("store_id") @db.Uuid
  date              DateTime @map("date") @db.Date
  hourStart         Int      @map("hour_start") // 0–23
  traffic           Int?
  salesCents        BigInt?  @map("sales_cents")
  saleTrxCount      Int?     @map("sale_trx_count")
  returnTrxCount    Int?     @map("return_trx_count")
  convRate          Float?   @map("conv_rate")
  atv               Float?
  shopperYield      Float?   @map("shopper_yield")
  captureRate       Float?   @map("capture_rate")
  visitDurationSecs Int?     @map("visit_duration_secs")
  ingestRunId       String   @map("ingest_run_id") @db.Uuid
  receivedAt        DateTime @default(now()) @map("received_at") @db.Timestamptz(6)

  store     Store               @relation(fields: [storeId], references: [id])
  ingestRun RetailNextIngestRun @relation(fields: [ingestRunId], references: [id])

  @@unique([storeId, date, hourStart])
  @@index([storeId, date(sort: Desc)])
  @@map("retailnext_hourly_snapshots")
}

// =========== v1 customer dashboard (auth + billing) ===========
//
// Customer dashboard auth layer (User / ClientMembership / MagicLinkToken)
// plus billing (Subscription / PlayerBinding) for the Entuned v1 paid
// onboarding flow (Stripe Checkout + Customer Portal).
//
// Customer = Client (Card 03 Duke). Site = Store (Card 03 Duke). The earlier
// parallel models (Account, Location, AccountMembership) were merged into
// Client/Store on 2026-05-04 — see `entune v0.3/schema/dashboard-auth.md`
// and `dashboard-billing.md` deprecation banners.
//
// `User` here is for end-customer dashboard users (the people who manage
// their stores via app.entuned.co). Distinct from the existing `Operator`
// model, which authenticates in-store player operators.
//
// Conventions matched to canonical schema.prisma:
//   - All ids are `String @id @default(uuid()) @db.Uuid` (Postgres-uuid).
//   - `email` columns use `@db.Citext` for case-insensitive lookups.
//   - SSOT lives in `../../../entune v0.3/schema/`; mirrored there too.
//
// `Location.tier` and `Subscription.status` are intentionally string fields
// (rather than Postgres enums) so adding new tiers/statuses does not require
// an enum migration. Validation happens at the route layer with zod.

// ---------- Customer dashboard auth (post-merger 2026-05-04 / 2026-05-09) ----------
//
// `Account` was merged into `Client` (its sole field `stripe_customer_id`
// moved to Client). `Location` was merged into `Store` (slug, tier,
// paused_until, archived_at moved to Store). `AccountMembership` was renamed
// to `ClientMembership`. `Subscription` and `PlayerBinding` survived but
// their FK repointed from location_id → store_id.
//
// 2026-05-09: `User` was merged into the unified `Account` table above. This
// section now contains only `ClientMembership` (FK repointed to Account) and
// `MagicLinkToken` (unchanged — keyed by email, no FK).

model ClientMembership {
  id        String   @id @default(uuid()) @db.Uuid
  clientId  String   @map("client_id") @db.Uuid
  accountId String   @map("account_id") @db.Uuid
  // role is a string for now: 'owner' | 'manager'.
  // Promote to a Postgres enum (e.g., AccountRole) when we add more roles or want DB-level validation.
  role      String
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([clientId, accountId])
  @@index([accountId])
  @@index([clientId])
  @@map("client_memberships")
}

model MagicLinkToken {
  id         String    @id @default(uuid()) @db.Uuid
  email      String    @db.Citext
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([email])
  @@index([expiresAt])
  @@map("magic_link_tokens")
}

// Account password reset. Distinct from MagicLinkToken: scoped to a specific
// Account (FK), 60-minute TTL, single-use. Token plaintext is sent in email;
// only sha256 of the token is stored.
model PasswordResetToken {
  id         String    @id @default(uuid()) @db.Uuid
  accountId  String    @map("account_id") @db.Uuid
  tokenHash  String    @unique @map("token_hash")
  expiresAt  DateTime  @map("expires_at") @db.Timestamptz(6)
  consumedAt DateTime? @map("consumed_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@index([accountId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

// ---------- Billing: Subscription ----------
//
// One Subscription row per Store. Mirrors the Stripe subscription state
// closely enough for the server to reason about access without round-tripping
// to Stripe on every request.
//
// `dunningAttempt` is incremented by `invoice.payment_failed` and reset by
// `invoice.payment_succeeded`. After 3 failed attempts the server flips
// `status` to 'past_due' and lets Stripe (per the dashboard's smart-retry
// settings) ultimately mark the subscription canceled.

model Subscription {
  id                   String   @id @default(uuid()) @db.Uuid
  storeId              String   @unique @map("store_id") @db.Uuid
  stripeSubscriptionId String   @unique @map("stripe_subscription_id")
  stripeCustomerId     String   @map("stripe_customer_id")
  stripePriceId        String   @map("stripe_price_id")
  status               String // 'active' | 'past_due' | 'paused' | 'canceled' | 'incomplete'
  currentPeriodEnd     DateTime @map("current_period_end") @db.Timestamptz(6)
  cancelAtPeriodEnd    Boolean  @default(false) @map("cancel_at_period_end")
  dunningAttempt       Int      @default(0) @map("dunning_attempt")
  createdAt            DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt            DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@index([stripeCustomerId])
  @@map("subscriptions")
}

// ---------- Billing: PlayerBinding ----------
//
// First device that opens the player at a Store is bound by fingerprint /
// IP / UA. Used as a soft anti-piracy signal — second devices either fall
// through to a "this Store is already bound" screen or trigger a manual
// review. Not enforced cryptographically.

model PlayerBinding {
  id          String   @id @default(uuid()) @db.Uuid
  storeId     String   @unique @map("store_id") @db.Uuid
  fingerprint String
  ip          String
  userAgent   String   @map("user_agent")
  boundAt     DateTime @default(now()) @map("bound_at") @db.Timestamptz(6)

  store Store @relation(fields: [storeId], references: [id], onDelete: Cascade)

  @@map("player_bindings")
}

// ---------- Email: editable templates ----------
//
// Templates live in the DB so the operator can edit voice without a server
// redeploy. lib/email.ts reads from this table at send time, falls back to
// the TS template registry if a row is missing (safety net so a wiped row
// can't break dunning / magic-link).
//
// `body` is raw HTML and is wrapped at render time by the shared `_layout`
// (see apps/server/src/email-templates/_layout.ts). Variables are
// interpolated with a Mustache-style `{{var}}` pass.

model EmailTemplate {
  id           String   @id @default(uuid()) @db.Uuid
  // Matches the keys in apps/server/src/email-templates/index.ts (TemplateName).
  name         String   @unique
  subject      String
  body         String
  // Sample props for the admin preview pane (stored as JSON for arbitrary shape).
  propsExample Json?    @map("props_example")
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  @@map("email_templates")
}

// ---------- Email: lifecycle send log (idempotency) ----------
//
// One row per (user, template, contextKey) — written under a unique constraint
// so the daily cron can re-run safely and never double-send a drip. contextKey
// distinguishes per-instance sends (e.g. one pause-ending warning per pause
// window). For "single global send" templates leave it as the default empty
// string; Postgres unique semantics treat '' as a real value, unlike NULL.

model LifecycleEmailLog {
  id           String   @id @default(uuid()) @db.Uuid
  accountId    String   @map("account_id") @db.Uuid
  templateName String   @map("template_name")
  contextKey   String   @default("") @map("context_key")
  sentAt       DateTime @default(now()) @map("sent_at") @db.Timestamptz(6)

  account Account @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, templateName, contextKey])
  @@index([accountId])
  @@map("lifecycle_email_logs")
}
