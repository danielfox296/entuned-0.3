{
  "name": "entuned-0.3",
  "version": "0.3.0",
  "private": true,
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev:server": "pnpm --filter server dev",
    "dev:player": "pnpm --filter player dev",
    "dev:admin": "pnpm --filter admin dev",
    "dev:dashboard": "pnpm --filter @entuned/dashboard dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck"
